# STAGING ENVIRONMENT - DO NOT PUT REAL SECRETS HERE
# This file is for template purposes only. Real secrets go in Railway dashboard.
# Copy this to .env.staging in Railway environment variables

# === Core Settings ===
NODE_ENV=staging
PORT=5001
FRONTEND_URL=https://nest.unearthoneearth.com
BACKEND_URL=https://nest.unearthoneearth.com/api

# === Database (SEPARATE from Production) ===
# NOTE: This is a SEPARATE MongoDB instance for staging only
# Production data is automatically cloned nightly and anonymized
# See: DATABASE_CLONE_GUIDE.md for details
#
# Get this URI from MongoDB Atlas > Staging Cluster > Connect > Node.js
MONGODB_URI=mongodb+srv://staging_user:staging_password@cluster-staging.mongodb.net/specialistly_staging?retryWrites=true&w=majority

# === Payment Gateways (Test Keys Only) ===
# Stripe Test Keys (NOT production)
STRIPE_SECRET_KEY=sk_test_your_staging_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_staging_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_staging_key_here

# Razorpay Test Keys (test mode)
RAZORPAY_KEY_ID=rzp_test_your_staging_key_here
RAZORPAY_KEY_SECRET=your_staging_secret_here

# === Email Configuration ===
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=staging@specialistly.com
MAIL_PASSWORD=your_staging_app_password_here
MAIL_FROM=staging@specialistly.com
RESEND_API_KEY=your_staging_resend_key_here

# === OAuth & Third-party ===
GOOGLE_OAUTH_CLIENT_ID=your_staging_google_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_staging_google_secret_here
GOOGLE_OAUTH_REDIRECT_URI=https://nest.unearthoneearth.com/auth/google/callback

ZOOM_CLIENT_ID=your_staging_zoom_client_id
ZOOM_CLIENT_SECRET=your_staging_zoom_secret
ZOOM_REDIRECT_URI=https://nest.unearthoneearth.com/auth/zoom/callback

# === JWT Secrets ===
JWT_SECRET=your_staging_jwt_secret_change_me_to_random_32_char_string
JWT_EXPIRE=7d

# === AWS Credentials ===
AWS_ACCESS_KEY_ID=staging_aws_key_here
AWS_SECRET_ACCESS_KEY=staging_aws_secret_here
AWS_S3_BUCKET=specialistly-staging-bucket
AWS_REGION=us-east-1

# === Logging ===
LOG_LEVEL=debug
LOG_FORMAT=json

# === Feature Flags ===
ENABLE_ANALYTICS=true
ENABLE_BETA_FEATURES=true
ENABLE_DEBUG_MODE=true

# === Session Settings ===
SESSION_SECRET=your_staging_session_secret_change_me
COOKIE_SECURE=true
COOKIE_SAME_SITE=Strict
